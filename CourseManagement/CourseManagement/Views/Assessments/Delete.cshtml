@model CourseManagementAPI.Models.Assessment

@{
    ViewData["Title"] = "Delete Assessment";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0 text-danger">Delete Assessment</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white"><strong>Confirm Deletion</strong></div>
            <div class="card-body">
                <p class="text-muted mb-3">
                    Are you sure you want to delete this assessment? Certification progress for the trainee
                    will be recalculated automatically after deletion.
                </p>

                <dl class="row">
                    <dt class="col-sm-4">Trainee</dt>
                    <dd class="col-sm-8">@Model.Enrollment?.Trainee?.FullName</dd>

                    <dt class="col-sm-4">Course</dt>
                    <dd class="col-sm-8">@Model.Enrollment?.Session?.Course?.CourseName</dd>

                    <dt class="col-sm-4">Instructor</dt>
                    <dd class="col-sm-8">@Model.Instructor?.FullName</dd>

                    <dt class="col-sm-4">Score</dt>
                    <dd class="col-sm-8">@(Model.Score?.ToString() ?? "—")</dd>

                    <dt class="col-sm-4">Result</dt>
                    <dd class="col-sm-8">
                        @if (Model.Result == 1)
                        {
                            <span class="badge bg-success">Pass</span>
                        }
                        else if (Model.Result == 0)
                        {
                            <span class="badge bg-danger">Fail</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-muted border">Not Graded</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="AssessmentId" />
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>
