@model CourseManagement.ViewModels.AssessmentDeleteViewModel

@{
    ViewData["Title"] = "Delete Assessment";
}

<div class="container mt-4">
    <h1>Delete Assessment</h1>
    <h3 class="text-danger">Are you sure you want to delete this assessment?</h3>
    <hr />
    <div class="card shadow-sm col-md-6 border-danger">
        <div class="card-body">
            <p class="text-muted mb-3">
                Certification progress for the trainee will be recalculated automatically after deletion.
            </p>

            <dl class="row">
                <dt class="col-sm-4">Trainee</dt>
                <dd class="col-sm-8">@Model.TraineeName</dd>

                <dt class="col-sm-4">Course</dt>
                <dd class="col-sm-8">@Model.CourseName</dd>

                <dt class="col-sm-4">Instructor</dt>
                <dd class="col-sm-8">@(Model.InstructorName ?? "—")</dd>

                <dt class="col-sm-4">Score</dt>
                <dd class="col-sm-8">@(Model.Score.HasValue ? Model.Score.ToString() : "—")</dd>

                <dt class="col-sm-4">Result</dt>
                <dd class="col-sm-8">
                    @if (Model.Result == 1) { <span class="badge bg-success">Pass</span> }
                    else if (Model.Result == 0) { <span class="badge bg-danger">Fail</span> }
                    else { <span class="badge bg-light text-muted border">Not Graded</span> }
                </dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" name="id" value="@Model.AssessmentId" />
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
