@model CourseManagement.ViewModels.AssessmentDetailsViewModel

@{
    ViewData["Title"] = "Assessment Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Assessment Details</h1>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white"><strong>Assessment #@Model.AssessmentId</strong></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Trainee</dt>
                        <dd class="col-sm-8">@Model.TraineeName</dd>

                        <dt class="col-sm-4">Course</dt>
                        <dd class="col-sm-8">@Model.CourseName</dd>

                        <dt class="col-sm-4">Session Start</dt>
                        <dd class="col-sm-8">@(Model.SessionStart?.ToString("yyyy-MM-dd HH:mm") ?? "—")</dd>

                        <dt class="col-sm-4">Instructor</dt>
                        <dd class="col-sm-8">@(Model.InstructorName ?? "—")</dd>

                        <dt class="col-sm-4">Score</dt>
                        <dd class="col-sm-8">
                            @if (Model.Score.HasValue) { <span class="fw-semibold">@Model.Score / 100</span> }
                            else { <span class="text-muted">Not scored</span> }
                        </dd>

                        <dt class="col-sm-4">Result</dt>
                        <dd class="col-sm-8">
                            @if (Model.Result == 1) { <span class="badge bg-success fs-6">Pass</span> }
                            else if (Model.Result == 0) { <span class="badge bg-danger fs-6">Fail</span> }
                            else { <span class="badge bg-light text-muted border">Not Graded</span> }
                        </dd>
                    </dl>
                </div>
                @if (User.IsInRole("TrainingCoordinator") || User.IsInRole("Instructor"))
                {
                    <div class="card-footer d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.AssessmentId" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@Model.AssessmentId" class="btn btn-danger btn-sm">Delete</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
