@model CourseManagement.ViewModels.AssessmentEditViewModel

@{
    ViewData["Title"] = "Edit Assessment";
    bool isInstructor = User.IsInRole("Instructor") && !User.IsInRole("TrainingCoordinator");
}

<div class="container mt-4">
    <h1>Edit Assessment #@Model.AssessmentId</h1>
    <hr />
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="AssessmentId" />

                <div class="mb-3">
                    <label asp-for="EnrollmentId" class="form-label"></label>
                    <select asp-for="EnrollmentId" asp-items="Model.Enrollments" class="form-select">
                        <option value="">-- Select Enrollment --</option>
                    </select>
                    <span asp-validation-for="EnrollmentId" class="text-danger"></span>
                    @if (isInstructor)
                    {
                        <div class="form-text text-muted">Only trainees enrolled in your assigned sessions are listed.</div>
                    }
                </div>

                @if (isInstructor)
                {
                    <input type="hidden" asp-for="InstructorId" />
                    <div class="mb-3">
                        <label class="form-label">Instructor</label>
                        <input type="text" class="form-control bg-light"
                               value="@(Model.Instructors.FirstOrDefault()?.Text ?? "—")" readonly />
                        <div class="form-text text-muted">Assessments are recorded under your own instructor profile.</div>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label asp-for="InstructorId" class="form-label"></label>
                        <select asp-for="InstructorId" asp-items="Model.Instructors" class="form-select">
                            <option value="">-- Select Instructor --</option>
                        </select>
                        <span asp-validation-for="InstructorId" class="text-danger"></span>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Score" class="form-label">Score (0 – 100)</label>
                    <input asp-for="Score" type="number" min="0" max="100" class="form-control" />
                    <span asp-validation-for="Score" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Result" class="form-label"></label>
                    <select asp-for="Result" class="form-select">
                        <option value="">-- Not Graded --</option>
                        <option value="1">Pass</option>
                        <option value="0">Fail</option>
                    </select>
                    <span asp-validation-for="Result" class="text-danger"></span>
                </div>

                <div class="alert alert-info small py-2 mb-3">
                    Certification progress is recalculated automatically on save.
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
