@model CourseManagement.ViewModels.CourseReqEqCreateViewModel

@{
    ViewData["Title"] = "Add Course Equipment Requirement";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-3">
                    <label asp-for="CourseId" class="form-label"></label>
                    <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId">
                        <option value="">-- Select Course --</option>
                    </select>
                    <span asp-validation-for="CourseId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EquipmentId" class="form-label"></label>
                    <select asp-for="EquipmentId" class="form-select" asp-items="ViewBag.EquipmentId">
                        <option value="">-- Select Equipment --</option>
                    </select>
                    <span asp-validation-for="EquipmentId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
