@model CourseManagementAPI.Models.TraineeCertificationProgress

@{
    ViewData["Title"] = "Delete Certification Progress";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0 text-danger">Delete Certification Progress</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white"><strong>Confirm Deletion</strong></div>
            <div class="card-body">
                <p class="text-muted mb-3">
                    Are you sure you want to delete this certification progress record?
                    This action cannot be undone.
                </p>

                <dl class="row">
                    <dt class="col-sm-4">Trainee</dt>
                    <dd class="col-sm-8">@Model.Trainee?.FullName</dd>

                    <dt class="col-sm-4">Certification</dt>
                    <dd class="col-sm-8">@Model.Certification?.Name</dd>

                    <dt class="col-sm-4">Progress</dt>
                    <dd class="col-sm-8">
                        @{
                            var pctStr = Model.ProgressPercentage.ToString("F1",
                                System.Globalization.CultureInfo.InvariantCulture);
                        }
                        <div class="progress" style="height:18px;">
                            <div class="progress-bar bg-warning"
                                 role="progressbar"
                                 style="width:@pctStr%"
                                 aria-valuenow="@pctStr"
                                 aria-valuemin="0" aria-valuemax="100">
                                @Model.ProgressPercentage%
                            </div>
                        </div>
                    </dd>

                    <dt class="col-sm-4">Achieved Date</dt>
                    <dd class="col-sm-8">@(Model.AchievedDate?.ToString("yyyy-MM-dd") ?? "Not yet achieved")</dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                @* asp-action on the form tag automatically injects the anti-forgery token — no manual @Html.AntiForgeryToken() needed *@
                <form asp-action="Delete" asp-controller="TraineeCertificationProgress" method="post">
                    <input type="hidden" name="traineeId"       value="@Model.TraineeId" />
                    <input type="hidden" name="certificationId" value="@Model.CertificationId" />
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>
