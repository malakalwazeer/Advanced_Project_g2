@model IEnumerable<CourseManagementAPI.Models.TraineeCertificationProgress>

@{
    ViewData["Title"] = "Certification Progress";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Trainee Certification Progress</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add Record
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Trainee</th>
                    <th>Certification</th>
                    <th style="min-width:200px;">Progress</th>
                    <th class="text-center">Achieved Date</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Trainee?.FullName</td>
                        <td>@item.Certification?.Name</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height:18px;">
                                    @{
                                        var pct = (double)item.ProgressPercentage;
                                        var barClass = pct >= 100 ? "bg-success"
                                                     : pct >= 50  ? "bg-info"
                                                     : "bg-warning";
                                    }
                                    <div class="progress-bar @barClass"
                                         role="progressbar"
                                         style="width:@pct%"
                                         aria-valuenow="@pct"
                                         aria-valuemin="0" aria-valuemax="100">
                                        @item.ProgressPercentage%
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td class="text-center">
                            @if (item.AchievedDate.HasValue)
                            {
                                <span class="badge bg-success">@item.AchievedDate.Value.ToString("yyyy-MM-dd")</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details"
                               asp-route-traineeId="@item.TraineeId"
                               asp-route-certificationId="@item.CertificationId"
                               class="btn btn-sm btn-outline-info me-1">Details</a>
                            <a asp-action="Edit"
                               asp-route-traineeId="@item.TraineeId"
                               asp-route-certificationId="@item.CertificationId"
                               class="btn btn-sm btn-outline-warning me-1">Edit</a>
                            <a asp-action="Delete"
                               asp-route-traineeId="@item.TraineeId"
                               asp-route-certificationId="@item.CertificationId"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No certification progress records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
