@model CourseManagementAPI.Models.Trainee

@{
    ViewData["Title"] = "Edit Trainee";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Edit Trainee</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-warning">
                <strong>Validation issues:</strong>
                <ul class="mb-0 mt-1">
                    @foreach (var kv in ViewData.ModelState.Where(m => m.Value!.Errors.Any()))
                    {
                        foreach (var err in kv.Value!.Errors)
                        {
                            <li><code>@kv.Key</code>: @err.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">Edit Trainee</div>
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <input type="hidden" asp-for="TraineeId" />

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="OrganizationName" class="form-label fw-semibold"></label>
                        <input asp-for="OrganizationName" class="form-control" />
                        <span asp-validation-for="OrganizationName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RegistrationDate" class="form-label fw-semibold"></label>
                        <input asp-for="RegistrationDate" type="date" class="form-control" />
                        <span asp-validation-for="RegistrationDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label fw-semibold"></label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password" type="password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TraineeStatusId" class="form-label fw-semibold">Status</label>
                        <select asp-for="TraineeStatusId" asp-items="ViewBag.TraineeStatusId" class="form-select">
                            <option value="">-- Select Status --</option>
                        </select>
                        <span asp-validation-for="TraineeStatusId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-warning">Save Changes</button>
                        <a asp-action="Details" asp-route-id="@Model.TraineeId" class="btn btn-outline-info">View Details</a>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
