@model IEnumerable<CourseManagement.ViewModels.TraineeIndexViewModel>

@{
    ViewData["Title"] = "Trainees";
    string? currentSearch = ViewBag.SearchString as string;
    int?    currentStatus = ViewBag.StatusId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Trainees</h2>
    @if (User.IsInRole("TrainingCoordinator"))
    {
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Index" method="get" class="row g-3 mb-4 align-items-end">
    <div class="col-md-4">
        <label class="form-label">Search</label>
        <input type="text"
               name="searchString"
               value="@currentSearch"
               class="form-control"
               placeholder="Name, email or organization..." />
    </div>

    <div class="col-md-3">
        <label class="form-label">Status</label>
        <select name="statusId" asp-items="@ViewBag.Statuses" class="form-select">
            <option value="">All Statuses</option>
        </select>
    </div>

    <div class="col-md-5 d-flex gap-2 align-items-end">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No matching records were found.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Full Name</th>
                        <th>Organization</th>
                        <th>Registration Date</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FullName</td>
                            <td>@(item.OrganizationName ?? "—")</td>
                            <td>@(item.RegistrationDate.ToString("yyyy-MM-dd"))</td>
                            <td>@item.Email</td>
                            <td>@item.Phone</td>
                            <td><span class="badge bg-secondary">@item.StatusName</span></td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.TraineeId" class="btn btn-sm btn-outline-info me-1">Details</a>
                                @if (User.IsInRole("TrainingCoordinator"))
                                {
                                    <a asp-action="Edit"   asp-route-id="@item.TraineeId" class="btn btn-sm btn-outline-warning me-1">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.TraineeId" class="btn btn-sm btn-outline-danger">Delete</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
