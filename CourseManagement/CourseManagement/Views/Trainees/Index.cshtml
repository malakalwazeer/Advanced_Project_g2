@model IEnumerable<CourseManagement.ViewModels.TraineeIndexViewModel>

@{
    ViewData["Title"] = "Trainees";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Trainees</h2>
    @if (User.IsInRole("TrainingCoordinator"))
    {
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Full Name</th>
                    <th>Organization</th>
                    <th>Registration Date</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@(item.OrganizationName ?? "—")</td>
                        <td>@(item.RegistrationDate.ToString("yyyy-MM-dd"))</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td><span class="badge bg-secondary">@item.StatusName</span></td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.TraineeId" class="btn btn-sm btn-outline-info me-1">Details</a>
                            @if (User.IsInRole("TrainingCoordinator"))
                            {
                                <a asp-action="Edit"   asp-route-id="@item.TraineeId" class="btn btn-sm btn-outline-warning me-1">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.TraineeId" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No trainees found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
