@model CourseManagementAPI.Models.Trainee

@{
    ViewData["Title"] = "Delete Trainee";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0 text-danger">Delete Trainee</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <strong>Confirm Deletion</strong>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">Are you sure you want to delete this trainee? This action cannot be undone.</p>

                <dl class="row">
                    <dt class="col-sm-4">Full Name</dt>
                    <dd class="col-sm-8">@Model.FullName</dd>

                    <dt class="col-sm-4">Organization</dt>
                    <dd class="col-sm-8">@(Model.OrganizationName ?? "—")</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@Model.TraineeStatus?.StatusName</span>
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="TraineeId" />
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>
