@model CourseManagement.ViewModels.TraineeDeleteViewModel

@{
    ViewData["Title"] = "Delete Trainee";
}

<div class="container mt-4">
    <h1>Delete Trainee</h1>
    <h3 class="text-danger">Are you sure you want to delete this trainee?</h3>
    <hr />
    <div class="card shadow-sm col-md-6 border-danger">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Full Name</dt>
                <dd class="col-sm-8">@Model.FullName</dd>

                <dt class="col-sm-4">Organization</dt>
                <dd class="col-sm-8">@(Model.OrganizationName ?? "—")</dd>

                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@Model.Email</dd>

                <dt class="col-sm-4">Phone</dt>
                <dd class="col-sm-8">@Model.Phone</dd>

                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8"><span class="badge bg-secondary">@Model.StatusName</span></dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" name="id" value="@Model.TraineeId" />
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
