@model CourseManagement.ViewModels.CourseIndexViewModel

@{
    ViewData["Title"] = "Delete Course";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>
    <h3 class="text-danger">Are you sure you want to delete this course?</h3>
    
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    
    <hr />
    <div class="card shadow-sm col-md-6 border-danger">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Code</dt>
                <dd class="col-sm-8">@Model.CourseCode</dd>

                <dt class="col-sm-4">Title</dt>
                <dd class="col-sm-8">@Model.Title</dd>

                <dt class="col-sm-4">Category</dt>
                <dd class="col-sm-8">@Model.CategoryName</dd>

                <dt class="col-sm-4">Fee</dt>
                <dd class="col-sm-8">@Model.Fee.ToString("C")</dd>
            </dl>
            
            <form asp-action="Delete">
                <input type="hidden" asp-for="CourseId" />
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
