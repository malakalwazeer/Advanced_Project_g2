@model IEnumerable<CourseManagement.ViewModels.CourseIndexViewModel>

@{
    ViewData["Title"] = "Course Catalog";
    string? currentSearch   = ViewBag.SearchString as string;
    int?    currentCategory = ViewBag.CategoryId as int?;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@ViewData["Title"]</h1>
        @if (User.IsInRole("TrainingCoordinator"))
        {
            <a asp-action="Create" class="btn btn-primary">Add New Course</a>
        }
    </div>

    <form asp-action="Index" method="get" class="row g-3 mb-4 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Search</label>
            <input type="text"
                   name="searchString"
                   value="@currentSearch"
                   class="form-control"
                   placeholder="Title, code or description..." />
        </div>

        <div class="col-md-3">
            <label class="form-label">Category</label>
            <select name="categoryId" asp-items="@ViewBag.Categories" class="form-select">
                <option value="">All Categories</option>
            </select>
        </div>

        <div class="col-md-5 d-flex gap-2 align-items-end">
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No matching records were found.</div>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Code</th>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Fee</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CourseCode</td>
                        <td>@item.Title</td>
                        <td>@item.CategoryName</td>
                        <td>@item.Fee.ToString("C")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.CourseId" class="btn btn-sm btn-info">Details</a>
                            @if (User.IsInRole("TrainingCoordinator"))
                            {
                                <a asp-action="Edit"   asp-route-id="@item.CourseId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.CourseId" class="btn btn-sm btn-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
