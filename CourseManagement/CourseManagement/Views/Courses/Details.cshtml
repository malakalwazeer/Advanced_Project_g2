                        <input type="hidden" asp-for="CourseId" />
                        <div class="col-12">
                            <select asp-for="AddPrerequisiteId" asp-items="Model.PrerequisiteCourseList" class="form-select" required>
                                <option value="">-- Select Course --</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-success">Add</button>
                        </div>
                    </form>
                    
                }
            </div>
        </div>
    </div>
</div>
@* added by malak *@
@if (User.IsInRole("Trainee"))
{
    <div class="card mt-4">
        <div class="card-header bg-dark text-white">
            Available Sessions
        </div>

        <div class="card-body">
            @if (Model.AvailableSessions.Any())
            {
                <table class="table table-sm table-striped">
                    <thead>
                        <tr>
                            <th>Instructor</th>
                            <th>Location</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Capacity</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model.AvailableSessions)
                        {
                            <tr>
                                <td>@session.InstructorName</td>
                                <td>@session.ClassroomLocation</td>
                                <td>@session.StartDateTime.ToString("g")</td>
                                <td>@session.EndDateTime.ToString("g")</td>
                                <td>@session.Capacity</td>
                                <td>
                                    <form asp-controller="Enrollments" asp-action="EnrollInSession" method="post" class="d-inline">
                                        <input type="hidden" name="sessionId" value="@session.SessionId" />
                                        <button type="submit" class="btn btn-success btn-sm">Enroll</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    No available sessions for this course yet.
                </div>
            }
        </div>
    </div>
}

<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex align-items-center gap-2">
                <strong>Sessions &amp; Live Enrollment</strong>
                <!-- Connection badge — toggled by the SignalR lifecycle callbacks below -->
                <span id="signalr-badge" class="badge bg-secondary ms-auto">Connecting…</span>
            </div>
            <div class="card-body p-0">
                @if (Model.Sessions.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Session</th>
                                    <th class="text-center" style="width:110px">Enrolled</th>
                                    <th class="text-center" style="width:90px">Capacity</th>
                                    <th class="text-center" style="width:110px">Remaining</th>
                                    <th style="min-width:160px">Fill Level</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.Sessions)
                                {
                                    <!-- Each row keyed by sessionId so the JS can locate it -->
                                    <tr id="session-row-@s.SessionId">
                                        <td>
                                            <div class="fw-semibold">@s.StartDateTime.ToString("MMM d, yyyy")</div>
                                            <small class="text-muted">
                                                @s.StartDateTime.ToString("HH:mm") – @s.EndDateTime.ToString("HH:mm")
                                            </small>
                                        </td>

                                        <!-- Enrolled count — patched by JS on each SignalR push -->
                                        <td class="text-center">
                                            <span id="enrolled-@s.SessionId" class="fw-bold fs-5">@s.EnrolledCount</span>
                                        </td>

                                        <td class="text-center text-muted">@s.Capacity</td>

                                        <!-- Remaining badge — class is also updated by JS -->
                                        <td class="text-center">
                                            <span id="remaining-@s.SessionId"
                                                  class="badge fs-6 @(s.IsFull ? "bg-danger" : s.RemainingSpots <= 3 ? "bg-warning text-dark" : "bg-success")">
                                                @(s.IsFull ? "Full" : s.RemainingSpots.ToString())
                                            </span>
                                        </td>

                                        <!-- Bootstrap progress bar — width and colour updated by JS -->
                                        <td>
                                            <div class="progress" style="height:10px"
                                                 title="@s.EnrolledCount / @s.Capacity enrolled">
                                                <div id="progress-@s.SessionId"
                                                     class="progress-bar @(s.IsFull ? "bg-danger" : s.RemainingSpots <= 3 ? "bg-warning" : "bg-success")"
                                                     role="progressbar"
                                                     style="width:@s.FillPercent%"
                                                     aria-valuenow="@s.EnrolledCount"
                                                     aria-valuemin="0"
                                                     aria-valuemax="@s.Capacity">
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">No sessions are scheduled for this course yet.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/9.0.6/signalr.min.js"></script>

    <script>
        const courseId = @Model.CourseId;

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/enrollment")
            .withAutomaticReconnect()
            .build();

        // Register server 
        connection.on("EnrollmentUpdated", function (sessions) {
            sessions.forEach(function (s) {
                const pct = s.capacity > 0
                    ? Math.round(s.enrolledCount / s.capacity * 100)
                    : 0;

                const barColour  = s.isFull          ? "bg-danger"
                                 : s.remainingSpots <= 3 ? "bg-warning"
                                 : "bg-success";

                const badgeClass = s.isFull          ? "badge fs-6 bg-danger"
                                 : s.remainingSpots <= 3 ? "badge fs-6 bg-warning text-dark"
                                 : "badge fs-6 bg-success";

                // Update enrolled count cell
                const enrolledEl = document.getElementById("enrolled-" + s.sessionId);
                if (enrolledEl) enrolledEl.textContent = s.enrolledCount;

                // Update remaining spots badge
                const remainEl = document.getElementById("remaining-" + s.sessionId);
                if (remainEl) {
                    remainEl.textContent = s.isFull ? "Full" : s.remainingSpots;
                    remainEl.className   = badgeClass;
                }

                // Update Bootstrap progress bar
                const progressEl = document.getElementById("progress-" + s.sessionId);
                if (progressEl) {
                    progressEl.style.width = pct + "%";
                    progressEl.className   = "progress-bar " + barColour;
                    progressEl.setAttribute("aria-valuenow", s.enrolledCount);
                }
            });
        });

        //Reconnect lifecycle hooks
        connection.onreconnecting(function () {
            document.getElementById("signalr-badge").textContent = "Reconnecting...";
            document.getElementById("signalr-badge").className   = "badge ms-auto bg-warning text-dark";
        });

        // After an automatic reconnect, group membership is lost invoke JoinCourseGroup again to re-subscribe.
        connection.onreconnected(function () {
            document.getElementById("signalr-badge").textContent = "Live";
            document.getElementById("signalr-badge").className   = "badge ms-auto bg-success";
            connection.invoke("JoinCourseGroup", courseId).catch(console.error);
        });

        connection.onclose(function () {
            document.getElementById("signalr-badge").textContent = "Disconnected";
            document.getElementById("signalr-badge").className   = "badge ms-auto bg-danger";
        });

        // Start the connection, then join the course group 
        connection.start()
            .then(function () {
                document.getElementById("signalr-badge").textContent = "Live";
                document.getElementById("signalr-badge").className   = "badge ms-auto bg-success";
                return connection.invoke("JoinCourseGroup", courseId);
            })
            .catch(function (err) {
                console.error("SignalR connection error:", err);
                document.getElementById("signalr-badge").textContent = "Offline";
                document.getElementById("signalr-badge").className   = "badge ms-auto bg-danger";
            });

        //Leave the group on page unload
        window.addEventListener("beforeunload", function () {
            connection.invoke("LeaveCourseGroup", courseId).catch(function () {});
        });
    </script>
}
