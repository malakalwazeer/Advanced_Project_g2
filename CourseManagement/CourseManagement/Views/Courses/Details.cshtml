@model CourseManagement.ViewModels.CourseDetailsViewModel

@{
    ViewData["Title"] = "Course Details";
}

<div class="row">
    <!-- Left Column: Course Info -->
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">@Model.CourseName (@Model.CourseCode)</h4>
            </div>
            <div class="card-body">
                <p><strong>Description:</strong> @Model.Description</p>
                <p><strong>Duration:</strong> @Model.DurationHours hours</p>
                <p><strong>Capacity:</strong> @Model.Capacity</p>
                <a asp-action="Edit" asp-route-id="@Model.CourseId" class="btn btn-warning">Edit Course</a>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>

    <!-- Right Column: Requirements & Prerequisites -->
    <div class="col-md-6">
        
        <!-- Required Equipment -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">Required Equipment</div>
            <div class="card-body">
                <table class="table table-sm">
                    <thead><tr><th>Equipment</th><th>Qty</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var item in Model.CurrentRequirements)
                        {
                            <tr>
                                <td>@item.Equipment.EquipmentName</td>
                                <td>@item.Quantity</td>
                                <td>
                                    <form asp-action="RemoveEquipmentRequirement" method="post">
                                        <input type="hidden" name="courseId" value="@Model.CourseId" />
                                        <input type="hidden" name="equipmentId" value="@item.EquipmentId" />
                                        <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <hr />
                <form asp-action="AddEquipmentRequirement" method="post" class="row row-cols-lg-auto g-3 align-items-center">
                    <input type="hidden" asp-for="CourseId" />
                    <div class="col-12">
                        <select asp-for="AddEquipmentId" asp-items="Model.EquipmentList" class="form-select" required>
                            <option value="">-- Select Equipment --</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <input asp-for="AddEquipmentQuantity" class="form-control" placeholder="Qty" required />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-success">Add</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Prerequisites -->
        <div class="card">
            <div class="card-header bg-success text-white">Prerequisites</div>
            <div class="card-body">
                <ul class="list-group mb-3">
                    @foreach (var item in Model.CurrentPrerequisites)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @item.PrerequisiteCourse.CourseName
                            <form asp-action="RemovePrerequisite" method="post">
                                <input type="hidden" name="courseId" value="@Model.CourseId" />
                                <input type="hidden" name="prerequisiteId" value="@item.CoursePrerequisiteId" />
                                <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                            </form>
                        </li>
                    }
                </ul>
                <form asp-action="AddPrerequisite" method="post" class="row row-cols-lg-auto g-3 align-items-center">
                    <input type="hidden" asp-for="CourseId" />
                    <div class="col-12">
                        <select asp-for="AddPrerequisiteId" asp-items="Model.PrerequisiteCourseList" class="form-select" required>
                            <option value="">-- Select Course --</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-success">Add</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex align-items-center gap-2">
                <strong>Sessions &amp; Live Enrollment</strong>
                <!-- Connection badge — toggled by the SignalR lifecycle callbacks below -->
                <span id="signalr-badge" class="badge bg-secondary ms-auto">Connecting…</span>
            </div>
            <div class="card-body p-0">
                @if (Model.Sessions.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Session</th>
                                    <th class="text-center" style="width:110px">Enrolled</th>
                                    <th class="text-center" style="width:90px">Capacity</th>
                                    <th class="text-center" style="width:110px">Remaining</th>
                                    <th style="min-width:160px">Fill Level</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.Sessions)
                                {
                                    <!-- Each row keyed by sessionId so the JS can locate it -->
                                    <tr id="session-row-@s.SessionId">
                                        <td>
                                            <div class="fw-semibold">@s.StartDateTime.ToString("MMM d, yyyy")</div>
                                            <small class="text-muted">
                                                @s.StartDateTime.ToString("HH:mm") – @s.EndDateTime.ToString("HH:mm")
                                            </small>
                                        </td>

                                        <!-- Enrolled count — patched by JS on each SignalR push -->
                                        <td class="text-center">
                                            <span id="enrolled-@s.SessionId" class="fw-bold fs-5">@s.EnrolledCount</span>
                                        </td>

                                        <td class="text-center text-muted">@s.Capacity</td>

                                        <!-- Remaining badge — class is also updated by JS -->
                                        <td class="text-center">
                                            <span id="remaining-@s.SessionId"
                                                  class="badge fs-6 @(s.IsFull ? "bg-danger" : s.RemainingSpots <= 3 ? "bg-warning text-dark" : "bg-success")">
                                                @(s.IsFull ? "Full" : s.RemainingSpots.ToString())
                                            </span>
                                        </td>

                                        <!-- Bootstrap progress bar — width and colour updated by JS -->
                                        <td>
                                            <div class="progress" style="height:10px"
                                                 title="@s.EnrolledCount / @s.Capacity enrolled">
                                                <div id="progress-@s.SessionId"
                                                     class="progress-bar @(s.IsFull ? "bg-danger" : s.RemainingSpots <= 3 ? "bg-warning" : "bg-success")"
                                                     role="progressbar"
                                                     style="width:@s.FillPercent%"
                                                     aria-valuenow="@s.EnrolledCount"
                                                     aria-valuemin="0"
                                                     aria-valuemax="@s.Capacity">
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">No sessions are scheduled for this course yet.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@latest/dist/browser/signalr.min.js"></script>

    <script>
    (function () {
        "use strict";

        // courseId is embedded by Razor at render time — safe, integer only.
        var courseId = @Model.CourseId;
        var badge    = document.getElementById("signalr-badge");

        //set badge text and Bootstrap colour class
        function setBadge(text, colourClass) {
            badge.textContent = text;
            badge.className   = "badge ms-auto " + colourClass;
        }

        // Build a persistent connection to the enrollment hub
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/enrollment")
            .withAutomaticReconnect()   // retries on transient network drops
            .build();

        //called whenever enrollment counts change for any session in this course
        connection.on("UpdateEnrollmentCounts", function (sessions) {
            sessions.forEach(function (s) {
                var pct = s.capacity > 0
                    ? Math.round(s.enrolledCount / s.capacity * 100)
                    : 0;

                var barColour  = s.isFull ? "bg-danger"
                               : s.remainingSpots <= 3 ? "bg-warning"
                               : "bg-success";

                var badgeClass = s.isFull ? "badge fs-6 bg-danger"
                               : s.remainingSpots <= 3 ? "badge fs-6 bg-warning text-dark"
                               : "badge fs-6 bg-success";

                // Enrolled count
                var enrolledEl = document.getElementById("enrolled-" + s.sessionId);
                if (enrolledEl) enrolledEl.textContent = s.enrolledCount;

                // Remaining spots badge
                var remainEl = document.getElementById("remaining-" + s.sessionId);
                if (remainEl) {
                    remainEl.textContent = s.isFull ? "Full" : s.remainingSpots;
                    remainEl.className   = badgeClass;
                }

                // Progress bar width + colour
                var progressEl = document.getElementById("progress-" + s.sessionId);
                if (progressEl) {
                    progressEl.style.width    = pct + "%";
                    progressEl.className      = "progress-bar " + barColour;
                    progressEl.setAttribute("aria-valuenow", s.enrolledCount);
                }
            });
        });

        connection.onreconnecting(function () {
            setBadge("Reconnecting…", "bg-warning text-dark");
        });

        connection.onreconnected(function () {
            setBadge("Live", "bg-success");
            // Re-join the group after reconnect — SignalR group membership
            connection.invoke("JoinCourseGroup", courseId).catch(console.error);
        });

        connection.onclose(function () {
            setBadge("Disconnected", "bg-danger");
        });

        //Start connection and join this course's group
        connection.start()
            .then(function () {
                setBadge("Live", "bg-success");
                return connection.invoke("JoinCourseGroup", courseId);
            })
            .catch(function (err) {
                console.error("SignalR connection failed:", err);
                setBadge("Offline", "bg-danger");
            });

        //Leave the group cleanly when the user navigates away
        window.addEventListener("beforeunload", function () {
            connection.invoke("LeaveCourseGroup", courseId).catch(function () {});
        });
    }());
    </script>
}
