@model IEnumerable<CourseManagement.ViewModels.ClassroomIndexViewModel>

@{
    ViewData["Title"] = "Classrooms";
    string? currentSearch  = ViewBag.SearchString as string;
    bool?   currentActive  = ViewBag.IsActive as bool?;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">Create New Classroom</a>
    </div>

    <form asp-action="Index" method="get" class="row g-3 mb-4 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Search</label>
            <input type="text"
                   name="searchString"
                   value="@currentSearch"
                   class="form-control"
                   placeholder="Search by location..." />
        </div>

        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select name="isActive" class="form-select">
                <option value="">All Classrooms</option>
                <option value="true"  selected="@(currentActive == true)">Active</option>
                <option value="false" selected="@(currentActive == false)">Inactive</option>
            </select>
        </div>

        <div class="col-md-4 d-flex gap-2 align-items-end">
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No matching records were found.</div>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Location</th>
                    <th>Capacity</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Location</td>
                        <td>@item.Capacity</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit"   asp-route-id="@item.ClassroomId" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.ClassroomId" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
