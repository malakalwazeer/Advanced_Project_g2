@model ClassroomIndexViewModel

@{
    ViewData["Title"] = "Delete Classroom";
}

<h1 class="h3 mb-3">@ViewData["Title"]</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this classroom?
</div>

<dl class="row">
    <dt class="col-sm-2">Location</dt>
    <dd class="col-sm-10">@Model.Location</dd>

    <dt class="col-sm-2">Capacity</dt>
    <dd class="col-sm-10">@Model.Capacity</dd>

    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">
        @if (Model.IsActive)
        {
            <span class="badge text-bg-success">Active</span>
        }
        else
        {
            <span class="badge text-bg-secondary">Inactive</span>
        }
    </dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ClassroomId" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</form>
