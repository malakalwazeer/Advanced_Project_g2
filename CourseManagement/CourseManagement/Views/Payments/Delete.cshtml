@model CourseManagement.ViewModels.PaymentDeleteViewModel

@{
    ViewData["Title"] = "Delete Payment";
}

<div class="container mt-4">
    <h1>Delete Payment</h1>
    <h3 class="text-danger">Are you sure you want to delete this payment record?</h3>
    <hr />
    <div class="card shadow-sm col-md-6 border-danger">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Trainee</dt>
                <dd class="col-sm-8">@Model.TraineeName</dd>

                <dt class="col-sm-4">Course</dt>
                <dd class="col-sm-8">@Model.CourseName</dd>

                <dt class="col-sm-4">Amount Paid</dt>
                <dd class="col-sm-8">@(Model.AmountPaid.ToString("N2", System.Globalization.CultureInfo.InvariantCulture))</dd>

                <dt class="col-sm-4">Payment Date</dt>
                <dd class="col-sm-8">@(Model.PaymentDate.ToString("yyyy-MM-dd"))</dd>

                <dt class="col-sm-4">Balance Remaining</dt>
                <dd class="col-sm-8">@(Model.BalanceRemaining.HasValue ? Model.BalanceRemaining.Value.ToString("N2", System.Globalization.CultureInfo.InvariantCulture) : "—")</dd>

                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8"><span class="badge bg-secondary">@Model.StatusName</span></dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" name="id" value="@Model.PaymentId" />
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
