@model CourseManagementAPI.Models.Payment

@{
    ViewData["Title"] = "Edit Payment";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Edit Payment</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">Edit Payment #@Model.PaymentId</div>
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <input type="hidden" asp-for="PaymentId" />

                    <div class="mb-3">
                        <label asp-for="EnrollmentId" class="form-label fw-semibold">Enrollment</label>
                        <select asp-for="EnrollmentId" asp-items="ViewBag.EnrollmentId" class="form-select">
                            <option value="">-- Select Enrollment --</option>
                        </select>
                        <span asp-validation-for="EnrollmentId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AmountPaid" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text">SAR</span>
                            <input asp-for="AmountPaid" type="number" step="0.01" min="0" class="form-control" />
                        </div>
                        <span asp-validation-for="AmountPaid" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PaymentDate" class="form-label fw-semibold"></label>
                        <input asp-for="PaymentDate" type="date" class="form-control" />
                        <span asp-validation-for="PaymentDate" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-info small py-2">
                        <strong>Note:</strong> Balance and payment status are recalculated automatically on save.
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-warning">Save Changes</button>
                        <a asp-action="Details" asp-route-id="@Model.PaymentId" class="btn btn-outline-info">View Details</a>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
