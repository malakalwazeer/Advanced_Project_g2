@model CourseManagement.ViewModels.PaymentEditViewModel

@{
    ViewData["Title"] = "Edit Payment";
}

<div class="container mt-4">
    <h1>Edit Payment #@Model.PaymentId</h1>
    <hr />
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="PaymentId" />

                <div class="mb-3">
                    <label asp-for="EnrollmentId" class="form-label"></label>
                    <select asp-for="EnrollmentId" asp-items="Model.Enrollments" class="form-select">
                        <option value="">-- Select Enrollment --</option>
                    </select>
                    <span asp-validation-for="EnrollmentId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AmountPaid" class="form-label"></label>
                    <input asp-for="AmountPaid" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="AmountPaid" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PaymentDate" class="form-label"></label>
                    <input asp-for="PaymentDate" type="date" class="form-control" />
                    <span asp-validation-for="PaymentDate" class="text-danger"></span>
                </div>

                <div class="alert alert-info small py-2 mb-3">
                    Balance remaining and payment status are recalculated automatically on save.
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
