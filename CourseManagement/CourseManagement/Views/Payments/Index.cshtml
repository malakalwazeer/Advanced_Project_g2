@model IEnumerable<CourseManagement.ViewModels.PaymentIndexViewModel>

@{
    ViewData["Title"] = "Payments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Payments</h2>
    @if (User.IsInRole("TrainingCoordinator"))
    {
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Trainee</th>
                    <th>Course</th>
                    <th>Amount Paid</th>
                    <th>Payment Date</th>
                    <th>Balance Remaining</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TraineeName</td>
                        <td>@item.CourseName</td>
                        <td>@(item.AmountPaid.ToString("N2", System.Globalization.CultureInfo.InvariantCulture))</td>
                        <td>@(item.PaymentDate.ToString("yyyy-MM-dd"))</td>
                        <td>
                            @if (item.BalanceRemaining == 0)
                            {
                                <span class="text-success fw-semibold">Settled</span>
                            }
                            else
                            {
                                @(item.BalanceRemaining.HasValue ? item.BalanceRemaining.Value.ToString("N2", System.Globalization.CultureInfo.InvariantCulture) : "—")
                            }
                        </td>
                        <td>
                            @{
                                var badgeClass = item.StatusName switch
                                {
                                    "Paid"    => "bg-success",
                                    "Partial" => "bg-warning text-dark",
                                    _         => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@item.StatusName</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.PaymentId" class="btn btn-sm btn-outline-info me-1">Details</a>
                            @if (User.IsInRole("TrainingCoordinator"))
                            {
                                <a asp-action="Edit"   asp-route-id="@item.PaymentId" class="btn btn-sm btn-outline-warning me-1">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.PaymentId" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No payments found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
