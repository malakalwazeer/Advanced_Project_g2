@{
    ViewData["Title"] = "Training Coordinator Dashboard";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="fw-bold"><i class="bi bi-speedometer2 text-primary me-2"></i>Control Center</h1>
        <p class="text-muted">Central hub for managing course catalog, staff resources, and scheduling operations.</p>
    </div>

    <div class="card bg-primary text-white mb-4 border-0 shadow-sm">
        <div class="card-body p-4 d-flex align-items-center">
            <div class="me-4"><i class="bi bi-calendar-event display-4"></i></div>
            <div>
                <h3 class="card-title fw-bold">Course Sessions</h3>
                <p class="card-text mb-3 opacity-75">Schedule new classes, check instructor availability, and manage classroom bookings.</p>
                <a asp-controller="CourseSessions" asp-action="Index" class="btn btn-light fw-bold px-4">Manage Sessions</a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-uppercase text-secondary mb-3"><i class="bi bi-book me-2"></i>Catalog</h5>
                    <div class="list-group list-group-flush">
                        <a asp-controller="Courses" asp-action="Index" class="list-group-item list-group-item-action border-0 px-0">Courses</a>
                        <a asp-controller="CourseReqEquipment" asp-action="Index" class="list-group-item list-group-item-action border-0 px-0">Course Requirements</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-uppercase text-secondary mb-3"><i class="bi bi-people me-2"></i>Staff</h5>
                    <div class="list-group list-group-flush">
                        <a asp-controller="Instructors" asp-action="Index" class="list-group-item list-group-item-action border-0 px-0">Instructors</a>
                        <a asp-controller="InstructorAvailability" asp-action="Index" class="list-group-item list-group-item-action border-0 px-0">Availability</a>
                        <a asp-controller="InstructorExpertise" asp-action="Index" class="list-group-item list-group-item-action border-0 px-0">Expertise</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-uppercase text-secondary mb-3"><i class="bi bi-building me-2"></i>Resources</h5>
                    <div class="list-group list-group-flush">
                        <a asp-controller="Classrooms" asp-action="Index" class="list-group-item list-group-item-action border-0 px-0">Classrooms</a>
                        <a asp-controller="Equipment" asp-action="Index" class="list-group-item list-group-item-action border-0 px-0">Equipment</a>
                        <a asp-controller="ClassroomEquipment" asp-action="Index" class="list-group-item list-group-item-action border-0 px-0">Room Assignments</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .list-group-item-action:hover {
        color: #0d6efd;
        background-color: transparent;
        font-weight: 500;
    }
</style>
