@model CourseManagement.ViewModels.EnrollmentCreateViewModel

@{
    ViewData["Title"] = "Create Enrollment";
}

<h1 class="h3 mb-3">Create Enrollment</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="TraineeId" class="form-label"></label>
                <select asp-for="TraineeId" asp-items="Model.Trainees" class="form-select">
                    <option value="">-- Select Trainee --</option>
                </select>
                <span asp-validation-for="TraineeId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SessionId" class="form-label"></label>
                <select asp-for="SessionId" asp-items="Model.Sessions" class="form-select">
                    <option value="">-- Select Session --</option>
                </select>
                <span asp-validation-for="SessionId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EnrollmentDate" class="form-label"></label>
                <input asp-for="EnrollmentDate" type="date" class="form-control" />
                <span asp-validation-for="EnrollmentDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EnrollmentStatusId" class="form-label"></label>
                <select asp-for="EnrollmentStatusId" asp-items="Model.EnrollmentStatuses" class="form-select">
                    <option value="">-- Select Status --</option>
                </select>
                <span asp-validation-for="EnrollmentStatusId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
