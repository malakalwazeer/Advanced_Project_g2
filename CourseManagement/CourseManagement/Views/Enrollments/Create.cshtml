@model CourseManagementAPI.Models.Enrollment

@{
    ViewData["Title"] = "Create Enrollment";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Create Enrollment</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">New Enrollment</div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="TraineeId" class="form-label fw-semibold">Trainee</label>
                        <select asp-for="TraineeId" asp-items="ViewBag.TraineeId" class="form-select">
                            <option value="">-- Select Trainee --</option>
                        </select>
                        <span asp-validation-for="TraineeId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SessionId" class="form-label fw-semibold">Session</label>
                        <select asp-for="SessionId" asp-items="ViewBag.SessionId" class="form-select">
                            <option value="">-- Select Session --</option>
                        </select>
                        <span asp-validation-for="SessionId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EnrollmentDate" class="form-label fw-semibold">Enrollment Date</label>
                        <input asp-for="EnrollmentDate" type="date" class="form-control" />
                        <span asp-validation-for="EnrollmentDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EnrollmentStatusId" class="form-label fw-semibold">Status</label>
                        <select asp-for="EnrollmentStatusId" asp-items="ViewBag.EnrollmentStatusId" class="form-select">
                            <option value="">-- Select Status --</option>
                        </select>
                        <span asp-validation-for="EnrollmentStatusId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Create</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
