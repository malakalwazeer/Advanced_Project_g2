@model IEnumerable<CourseManagementAPI.Models.Enrollment>

@{
    ViewData["Title"] = "Enrollments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Enrollments</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Create New
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Trainee</th>
                    <th>Course</th>
                    <th>Session Start</th>
                    <th>Session End</th>
                    <th>Enrollment Date</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Trainee?.FullName</td>
                        <td>@item.Session?.Course?.CourseName</td>
                        <td>@item.Session?.StartDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@item.Session?.EndDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@item.EnrollmentDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <span class="badge bg-info text-dark">@item.EnrollmentStatus?.StatusName</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.EnrollmentId"
                               class="btn btn-sm btn-outline-info me-1">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.EnrollmentId"
                               class="btn btn-sm btn-outline-warning me-1">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.EnrollmentId"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No enrollments found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
