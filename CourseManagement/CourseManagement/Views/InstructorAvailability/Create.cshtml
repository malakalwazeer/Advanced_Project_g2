@model CourseManagement.ViewModels.AvailabilityCreateViewModel

@{
    ViewData["Title"] = "Add Availability";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-3">
                    <label asp-for="InstructorId" class="form-label">Instructor</label>
                    <select asp-for="InstructorId" class="form-select" asp-items="ViewBag.Instructors">
                        <option value="">-- Select Instructor --</option>
                    </select>
                    <span asp-validation-for="InstructorId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AvailableDate" class="form-label">Date</label>
                    <input asp-for="AvailableDate" class="form-control" type="date" />
                    <span asp-validation-for="AvailableDate" class="text-danger"></span>
                </div>

                <div class="row mb-3">
                    <div class="col">
                        <label asp-for="StartTime" class="form-label">Start Time</label>
                        <input asp-for="StartTime" class="form-control" type="time" />
                        <span asp-validation-for="StartTime" class="text-danger"></span>
                    </div>
                    <div class="col">
                        <label asp-for="EndTime" class="form-label">End Time</label>
                        <input asp-for="EndTime" class="form-control" type="time" />
                        <span asp-validation-for="EndTime" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsAvailable" class="form-check-input" />
                    <label asp-for="IsAvailable" class="form-check-label"></label>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Add Record</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
