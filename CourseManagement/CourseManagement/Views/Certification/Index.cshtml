@model IEnumerable<CourseManagement.ViewModels.CertificationIndexViewModel>

@{
    ViewData["Title"] = "Certifications";
    string? currentSearch = ViewBag.SearchString as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Certifications</h1>
        @if (User.IsInRole("TrainingCoordinator"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>New Certification
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Index" method="get" class="row g-3 mb-4 align-items-end">
        <div class="col-md-6">
            <label class="form-label">Search</label>
            <input type="text" name="searchString" value="@currentSearch"
                   class="form-control" placeholder="Certification name or description..." />
        </div>
        <div class="col-12 col-md-6 d-flex flex-wrap gap-2 align-items-end">
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No certifications found.</div>
    }
    else
    {
        <div class="table-responsive">
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th class="text-center">Linked Courses</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Name</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <span class="text-muted">@(item.Description.Length > 80 ? item.Description[..80] + "…" : item.Description)</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">—</span>
                            }
                        </td>
                        <td class="text-center"><span class="badge bg-secondary">@item.CourseCount</span></td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <a asp-action="Details" asp-route-id="@item.CertificationId" class="btn btn-sm btn-info">Details</a>
                                @if (User.IsInRole("TrainingCoordinator"))
                                {
                                    <a asp-action="Edit"   asp-route-id="@item.CertificationId" class="btn btn-sm btn-warning">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.CertificationId" class="btn btn-sm btn-danger">Delete</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>
