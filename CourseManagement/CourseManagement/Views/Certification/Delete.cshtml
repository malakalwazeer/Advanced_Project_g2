@model CourseManagement.ViewModels.CertificationDeleteViewModel

@{
    ViewData["Title"] = "Delete Certification";
}

<div class="container mt-4">
    <h1>Delete Certification</h1>
    <h3 class="text-danger">Are you sure you want to delete this certification?</h3>
    <hr />

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p class="mb-0">@error.ErrorMessage</p>
            }
        </div>
    }

    <div class="card shadow-sm col-md-6 border-danger">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Name</dt>
                <dd class="col-sm-8">@Model.Name</dd>

                <dt class="col-sm-4">Description</dt>
                <dd class="col-sm-8">
                    @if (!string.IsNullOrWhiteSpace(Model.Description)) { @Model.Description }
                    else { <span class="text-muted fst-italic">None</span> }
                </dd>

                <dt class="col-sm-4">Linked Courses</dt>
                <dd class="col-sm-8"><span class="badge bg-secondary">@Model.CourseCount</span></dd>

                <dt class="col-sm-4">Trainee Progress</dt>
                <dd class="col-sm-8">
                    @if (Model.ProgressCount > 0)
                    {
                        <span class="badge bg-danger">@Model.ProgressCount record(s) — cannot delete</span>
                    }
                    else
                    {
                        <span class="badge bg-success">None</span>
                    }
                </dd>
            </dl>

            <form asp-action="Delete" asp-route-id="@Model.CertificationId" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.CertificationId" />
                <button type="submit" class="btn btn-danger"
                        disabled="@(Model.ProgressCount > 0 ? "disabled" : null)">
                    <i class="bi bi-trash me-1"></i>Confirm Delete
                </button>
                <a asp-action="Details" asp-route-id="@Model.CertificationId" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
