@model CourseManagement.ViewModels.CertificationDeleteViewModel

@{
    ViewData["Title"] = "Delete Certification";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Delete Certification</h2>
    <a asp-action="Details" asp-route-id="@Model.CertificationId" class="btn btn-outline-secondary btn-sm">Back to Details</a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p class="mb-0">@error.ErrorMessage</p>
        }
    </div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <strong><i class="bi bi-exclamation-triangle me-2"></i>Confirm Deletion</strong>
            </div>
            <div class="card-body">
                <p class="mb-3">Are you sure you want to permanently delete this certification?</p>

                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrWhiteSpace(Model.Description))
                        { @Model.Description }
                        else
                        { <span class="text-muted fst-italic">None</span> }
                    </dd>

                    <dt class="col-sm-4">Linked Courses</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@Model.CourseCount</span>
                    </dd>

                    <dt class="col-sm-4">Trainee Progress</dt>
                    <dd class="col-sm-8">
                        @if (Model.ProgressCount > 0)
                        {
                            <span class="badge bg-danger">@Model.ProgressCount record(s) — cannot delete</span>
                        }
                        else
                        {
                            <span class="badge bg-success">None</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                <form asp-action="Delete" asp-route-id="@Model.CertificationId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.CertificationId" />
                    <button type="submit" class="btn btn-danger"
                            disabled="@(Model.ProgressCount > 0 ? "disabled" : null)">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </form>
                <a asp-action="Details" asp-route-id="@Model.CertificationId"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>
