@model CourseManagement.ViewModels.CertificationEditViewModel

@{
    ViewData["Title"] = "Edit Certification";
}

<div class="container mt-4">
    <h1>Edit Certification</h1>
    <hr />
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit" asp-route-id="@Model.CertificationId" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CertificationId" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">
                        Description <span class="text-muted">(optional)</span>
                    </label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Details" asp-route-id="@Model.CertificationId" class="btn btn-secondary">Back to Details</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
