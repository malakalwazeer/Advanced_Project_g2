@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center py-5">
    <h1 class="display-4 mb-3">Welcome to CourseManagement</h1>
    <p class="lead text-muted mb-4">Manage courses, enrollments, and professional certifications in one place.</p>
</div>

<div class="row justify-content-center g-4 mb-5">
    <div class="col-md-5">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body d-flex flex-column p-4">
                <div class="mb-3">
                    <i class="bi bi-patch-check-fill fs-2 text-primary"></i>
                </div>
                <h5 class="card-title">Verify a Certificate</h5>
                <p class="card-text text-muted flex-grow-1">
                    Instantly verify the authenticity of any certification issued through this platform.
                    No account required — open to the public.
                </p>
                <a asp-controller="PublicCertificationLookup"
                   asp-action="Index"
                   class="btn btn-primary mt-3 align-self-start">
                    <i class="bi bi-search me-1"></i>Verify Certification
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body d-flex flex-column p-4">
                <div class="mb-3">
                    <i class="bi bi-mortarboard-fill fs-2" style="color: var(--brand-navy);"></i>
                </div>
                <h5 class="card-title">Browse Courses</h5>
                <p class="card-text text-muted flex-grow-1">
                    Explore our full catalog of training courses, sessions, and professional development programs.
                </p>
                <a asp-controller="Account"
                   asp-action="Login"
                   class="btn btn-outline-secondary mt-3 align-self-start">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Sign In to Enroll
                </a>
            </div>
        </div>
    </div>
</div>
