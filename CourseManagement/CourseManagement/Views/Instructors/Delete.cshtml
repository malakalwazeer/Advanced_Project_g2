@model InstructorIndexViewModel

@{
    ViewData["Title"] = "Delete Instructor";
}

<h1 class="h3 mb-3">@ViewData["Title"]</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this instructor?
</div>

<dl class="row">
    <dt class="col-sm-2">Full Name</dt>
    <dd class="col-sm-10">@Model.FullName</dd>

    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.Email</dd>

    <dt class="col-sm-2">Phone</dt>
    <dd class="col-sm-10">@Model.Phone</dd>

    <dt class="col-sm-2">Qualifications</dt>
    <dd class="col-sm-10">@Model.Qualifications</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="InstructorId" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</form>
