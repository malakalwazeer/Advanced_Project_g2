@model CourseManagement.ViewModels.EquipmentIndexViewModel

@{
    ViewData["Title"] = "Delete Equipment";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>
    <h3 class="text-danger">Are you sure you want to delete this equipment?</h3>
    <hr />
    <div class="card shadow-sm col-md-6 border-danger">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Name</dt>
                <dd class="col-sm-8">@Model.EquipmentName</dd>

                <dt class="col-sm-4">Description</dt>
                <dd class="col-sm-8">@Model.Description</dd>
            </dl>
            
            <form asp-action="Delete">
                <input type="hidden" asp-for="EquipmentId" />
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
