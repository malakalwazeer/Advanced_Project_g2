@model CourseManagement.ViewModels.PublicCertificationLookupViewModel

@{
    ViewData["Title"] = "Certificate Verification";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-7">

            <div class="d-flex align-items-center mb-4">
                <i class="bi bi-patch-check-fill text-primary fs-3 me-2"></i>
                <div>
                    <h1 class="h3 mb-0">Certificate Verification</h1>
                    <p class="text-muted mb-0 small">
                        Enter your Trainee ID and Certificate Reference Number to verify your certification.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <i class="bi bi-search me-1"></i> Verify Your Certificate
                </div>
                <div class="card-body">
                    <form asp-action="Index" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="TraineeId" class="form-label">Trainee ID</label>
                            <input asp-for="TraineeId" type="number" class="form-control"
                                   placeholder="e.g. 42" min="1" />
                            <span asp-validation-for="TraineeId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CertificateReferenceNumber" class="form-label">Certificate Reference Number</label>
                            <input asp-for="CertificateReferenceNumber" class="form-control"
                                   placeholder="e.g. CERT-42-3" />
                            <div class="form-text">Format: <code>CERT-{TraineeId}-{CertificationId}</code></div>
                            <span asp-validation-for="CertificateReferenceNumber" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search me-1"></i>Verify
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @if (Model.HasResult)
            {
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger" role="alert">
                        <strong>Verification Error</strong><br />
                        @Model.ErrorMessage
                    </div>
                }
                else if (!Model.IsValid)
                {
                    <div class="card shadow-sm border-danger">
                        <div class="card-header bg-danger text-white">
                            <i class="bi bi-x-circle me-1"></i> Certificate Not Valid
                        </div>
                        <div class="card-body">
                            <div class="alert alert-danger py-2 mb-3">@Model.Message</div>

                            <dl class="row mb-0">
                                <dt class="col-sm-4">Trainee</dt>
                                <dd class="col-sm-8 fw-semibold">@Model.TraineeName</dd>

                                <dt class="col-sm-4">Certification</dt>
                                <dd class="col-sm-8 fw-semibold">@Model.CertificationName</dd>

                                <dt class="col-sm-4">Progress</dt>
                                <dd class="col-sm-8">
                                    @Model.CompletedCoursesCount / @Model.RequiredCoursesCount courses completed
                                    (@Model.ProgressPercentage.ToString("F1")%)
                                </dd>
                            </dl>

                            @if (Model.MissingCourses.Any())
                            {
                                <h6 class="fw-semibold mt-3 mb-2">Missing Courses</h6>
                                <ul class="mb-0">
                                    @foreach (var course in Model.MissingCourses)
                                    {
                                        <li>@course</li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="card shadow-sm border-success">
                        <div class="card-header bg-success text-white">
                            <i class="bi bi-patch-check me-1"></i> Certificate Verified
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(Model.Message))
                            {
                                <div class="alert alert-success py-2 mb-3">@Model.Message</div>
                            }

                            <dl class="row mb-0">
                                <dt class="col-sm-4">Trainee</dt>
                                <dd class="col-sm-8 fw-semibold">@Model.TraineeName</dd>

                                <dt class="col-sm-4">Certification</dt>
                                <dd class="col-sm-8 fw-semibold">@Model.CertificationName</dd>

                                <dt class="col-sm-4">Reference</dt>
                                <dd class="col-sm-8"><code>@Model.CertificateReferenceNumber</code></dd>

                                <dt class="col-sm-4">Progress</dt>
                                <dd class="col-sm-8">
                                    @Model.CompletedCoursesCount / @Model.RequiredCoursesCount courses completed
                                    <div class="progress mt-1" style="height: 10px;">
                                        <div class="progress-bar bg-success" role="progressbar"
                                             style="width: @(Model.ProgressPercentage.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%"
                                             aria-valuenow="@Model.ProgressPercentage.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                             aria-valuemin="0" aria-valuemax="100">
                                        </div>
                                    </div>
                                    <small class="text-muted">@Model.ProgressPercentage.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%</small>
                                </dd>
                            </dl>

                            @if (Model.CompletedCourses.Any())
                            {
                                <h6 class="fw-semibold mt-3 mb-2 text-success">Completed Courses</h6>
                                <ul class="list-group list-group-flush">
                                    @foreach (var course in Model.CompletedCourses)
                                    {
                                        <li class="list-group-item d-flex align-items-center gap-2 ps-0 border-0">
                                            <i class="bi bi-check-circle-fill text-success"></i> @course
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                }
            }

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
