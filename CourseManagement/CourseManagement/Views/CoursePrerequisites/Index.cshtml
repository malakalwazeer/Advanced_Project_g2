@model IEnumerable<CourseManagement.ViewModels.CoursePrerequisiteIndexViewModel>

@{
    ViewData["Title"] = "Course Prerequisites";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">Add Prerequisite</a>
    </div>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Course Name</th>
                <th>Prerequisite Course</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CourseName</td>
                    <td>@item.PrerequisiteCourseName</td>
                    <td>
                        <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to remove this prerequisite?');" class="d-inline">
                            <input type="hidden" name="courseId" value="@item.CourseId" />
                            <input type="hidden" name="prerequisiteId" value="@item.PrerequisiteCourseId" />
                            <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
