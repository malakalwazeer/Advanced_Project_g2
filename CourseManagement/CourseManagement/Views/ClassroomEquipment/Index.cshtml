@model IEnumerable<CourseManagement.ViewModels.ClassroomEqIndexViewModel>

@{
    ViewData["Title"] = "Classroom Equipment";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">Assign Equipment to Room</a>
    </div>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Location</th>
                <th>Equipment Name</th>
                <th>Quantity</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.LocationName</td>
                    <td>@item.EquipmentName</td>
                    <td>@item.Quantity</td>
                    <td>
                        <a asp-action="Edit" asp-route-classroomId="@item.ClassroomId" asp-route-equipmentId="@item.EquipmentId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-classroomId="@item.ClassroomId" asp-route-equipmentId="@item.EquipmentId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
