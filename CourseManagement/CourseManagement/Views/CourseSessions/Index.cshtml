@model IEnumerable<CourseManagement.ViewModels.SessionIndexViewModel>

@{
    ViewData["Title"] = "Course Sessions";
    string? currentSearch     = ViewBag.SearchString as string;
    string? currentTimeFilter = ViewBag.TimeFilter as string;
    bool    currentAvailable  = ViewBag.AvailableOnly == true;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@ViewData["Title"]</h1>
        @if (User.IsInRole("TrainingCoordinator"))
        {
            <a asp-action="Create" class="btn btn-primary">Schedule New Session</a>
        }
    </div>

    <form asp-action="Index" method="get" class="row g-3 mb-4 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Search</label>
            <input type="text"
                   name="searchString"
                   value="@currentSearch"
                   class="form-control"
                   placeholder="Course title or instructor name..." />
        </div>

        <div class="col-md-3">
            <label class="form-label">Time</label>
            <select name="timeFilter" class="form-select">
                <option value="">All Times</option>
                <option value="upcoming" selected="@(currentTimeFilter == "upcoming")">Upcoming</option>
                <option value="past"     selected="@(currentTimeFilter == "past")">Past</option>
            </select>
        </div>

        <div class="col-md-2 d-flex align-items-end pb-1">
            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       name="availableOnly"
                       value="true"
                       id="availableOnly"
                       checked="@currentAvailable" />
                <label class="form-check-label" for="availableOnly">Available Only</label>
            </div>
        </div>

        <div class="col-md-3 d-flex gap-2 align-items-end">
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No matching records were found.</div>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Course</th>
                    <th>Instructor</th>
                    <th>Location</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Capacity</th>
                    @if (User.IsInRole("TrainingCoordinator") || User.IsInRole("Trainee"))
                    {
                    <th>Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CourseName</td>
                        <td>@item.InstructorName</td>
                        <td>@item.ClassroomLocation</td>
                        <td>@item.StartDateTime.ToString("g")</td>
                        <td>@item.EndDateTime.ToString("g")</td>
                        <td>@item.Capacity</td>
                        <td>
                            @if (User.IsInRole("TrainingCoordinator"))
                            {
                                <a asp-action="Edit"   asp-route-id="@item.SessionId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.SessionId" class="btn btn-sm btn-danger">Delete</a>
                            }
                            @if (User.IsInRole("Trainee"))
                            {
                                <form asp-controller="Enrollments" asp-action="EnrollInSession" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="sessionId" value="@item.SessionId" />
                                    <button type="submit" class="btn btn-sm btn-success">Enroll</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
