@model IEnumerable<CourseManagement.ViewModels.SessionIndexViewModel>

@{
    ViewData["Title"] = "Course Sessions";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">Schedule New Session</a>
    </div>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Course</th>
                <th>Instructor</th>
                <th>Location</th>
                <th>Start Time</th>
                <th>End Time</th>
                <th>Capacity</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CourseName</td>
                    <td>@item.InstructorName</td>
                    <td>@item.ClassroomLocation</td>
                    <td>@item.StartDateTime.ToString("g")</td>
                    <td>@item.EndDateTime.ToString("g")</td>
                    <td>@item.Capacity</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.SessionId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.SessionId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
