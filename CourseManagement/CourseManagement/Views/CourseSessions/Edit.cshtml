@model CourseManagement.ViewModels.SessionEditViewModel

@{
    ViewData["Title"] = "Edit Session";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>
    <hr />
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="SessionId" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="CourseId" class="form-label"></label>
                        <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId">
                            <option value="">-- Select Course --</option>
                        </select>
                        <span asp-validation-for="CourseId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="InstructorId" class="form-label"></label>
                        <select asp-for="InstructorId" class="form-select" asp-items="ViewBag.InstructorId">
                            <option value="">-- Select Instructor --</option>
                        </select>
                        <span asp-validation-for="InstructorId" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="ClassroomId" class="form-label"></label>
                        <select asp-for="ClassroomId" class="form-select" asp-items="ViewBag.ClassroomId">
                            <option value="">-- Select Classroom --</option>
                        </select>
                        <span asp-validation-for="ClassroomId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Capacity" class="form-label"></label>
                        <input asp-for="Capacity" class="form-control" type="number" />
                        <span asp-validation-for="Capacity" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="StartDateTime" class="form-label"></label>
                        <input asp-for="StartDateTime" class="form-control" type="datetime-local" value="@Model.StartDateTime.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="StartDateTime" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDateTime" class="form-label"></label>
                        <input asp-for="EndDateTime" class="form-control" type="datetime-local" value="@Model.EndDateTime.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="EndDateTime" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
