@model ReportingCourseManagement.Dtos.LoginDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Course Management System - Portal Authentication</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-secondary bg-opacity-10">
    <div class="container">
        <div class="row justify-content-center align-items-center min-vh-100">
            <div class="col-10 col-sm-8 col-md-6 col-lg-4">
                <div class="card border-0 shadow-lg">
                    <div class="card-header bg-dark text-white p-4 text-center">
                        <h5 class="mb-0 text-uppercase tracking-wide">Reporting Dashboard Login</h5>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="Login" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label font-monospace small text-muted">Email Address</label>
                                <input asp-for="Email" class="form-control" type="email" placeholder="name@example.local" required />
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label font-monospace small text-muted">System Password</label>
                                <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" required />
                            </div>

                            <button type="submit" class="btn btn-dark w-100 py-2 mt-2">Authenticate Session</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>