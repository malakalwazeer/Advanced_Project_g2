@model ReportingCourseManagement.Dtos.RevenueSummaryReportDto

@{
    ViewData["Title"] = "Revenue Summary";
}

<h2>Revenue Summary</h2>

@if (Model == null)
{
    <div class="alert alert-warning">
        No revenue data available.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Total Collected</th>
                <th>Total Outstanding</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@Model.TotalCollected</td>
                <td>@Model.TotalOutstanding</td>
            </tr>
        </tbody>
    </table>
}

<a asp-controller="Reports" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
