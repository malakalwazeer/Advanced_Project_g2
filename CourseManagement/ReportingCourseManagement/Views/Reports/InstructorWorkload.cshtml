@model List<ReportingCourseManagement.Dtos.InstructorWorkloadReportDto>

@{
    ViewData["Title"] = "Instructor Workload";
}

<h2>Instructor Workload</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Instructor Name</th>
            <th>Session Count</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.InstructorName</td>
                <td>@item.SessionCount</td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Reports" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>